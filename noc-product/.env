# Database
NOC_DATA_DSN=postgresql+psycopg://noc:noc@noc-data:5432/noc_data
NOC_GOV_DSN=postgresql+psycopg://noc:noc@noc-gov:5432/noc_gov
NOC_DATA_HOST=noc-data
NOC_DATA_PORT=5432
NOC_DATA_USER=noc
NOC_DATA_PASSWORD=noc
NOC_DATA_DB=noc_data
NOC_GOV_HOST=noc-gov
NOC_GOV_PORT=5432
NOC_GOV_USER=noc
NOC_GOV_PASSWORD=noc
NOC_GOV_DB=noc_gov

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ARCHIVE=noc-archive
MINIO_BUCKET_STAGING=noc-staging

# Vault (dev)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token
VAULT_KEK_PATH=secret/data/noc-gov/kek/current

# Dex OIDC
OIDC_ISSUER=http://dex:5556/dex
OIDC_CLIENT_ID=noc-reviewer
OIDC_CLIENT_SECRET=noc-reviewer-secret
OIDC_REDIRECT_URI=http://localhost:8080/auth/callback

# Model backend (Ollama on host)
MODEL_BACKEND=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_REASONING_MODEL=llama3.1:70b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SEC=120
OLLAMA_KEEPALIVE_SEC=60

# Chain-Write stub
CHAIN_WRITE_URL=http://chain-write:7001
CHAIN_WRITE_WAL_DIR=/var/wal
CHAIN_WRITE_STUB_NAMESPACE=6ba7b810-9dad-11d1-80b4-00c04fd430c8

# Mock CTTS
MOCK_CTTS_URL=http://mock-ctts:8001
CTTS_POLL_INTERVAL_SEC=15

# Reviewer UI
SESSION_SECRET=change-me-dev-only
SESSION_SLIDING_HOURS=8
SESSION_ABSOLUTE_HOURS=12

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAMESPACE=noc-product
PROMETHEUS_PORT=9464

# System versions
SYSTEM_VERSION=mvghb-w1-0.1.0
SOP_CORPUS_VERSION=v1

# MVGH-β activation
MVGHB_KEK=hm/UFQDkUv21LvRruKyM3VLdYtD5cG0SauO6f2CYI8U=

# MVGH-β activation
CHAIN_WRITE_MODE=real

# MVGH-β activation
MVGHB_SYSTEM_VERSION=mvghb-w1-0.1.0
