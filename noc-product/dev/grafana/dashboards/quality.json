{
  "uid": "noc-quality",
  "title": "NOC Quality",
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "Decisions — approve vs reject vs override (1h)",
      "targets": [
        {"expr": "sum by (kind) (increase(noc_operator_decisions_total[1h]))",
         "legendFormat": "{{kind}}"}
      ],
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Validation failures by rule (rate /5m)",
      "targets": [
        {"expr": "sum by (rule_id) (rate(noc_validation_failures_total[5m]))",
         "legendFormat": "{{rule_id}}"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Agent duration p95 (s) by agent_kind",
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (agent_kind, le) (rate(noc_agent_duration_seconds_bucket[5m])))",
         "legendFormat": "{{agent_kind}}"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}
    },
    {
      "type": "timeseries",
      "title": "Chain-Write emits by outcome",
      "targets": [
        {"expr": "sum by (outcome) (rate(noc_chain_emits_total[5m]))",
         "legendFormat": "{{outcome}}"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
