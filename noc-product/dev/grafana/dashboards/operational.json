{
  "uid": "noc-operational",
  "title": "NOC Operational",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Recommendation p95 latency (s)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(noc_recommendation_duration_seconds_bucket[5m])) by (le))"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Agent timeouts / 5m",
      "targets": [
        {"expr": "increase(noc_agent_timeouts_total[5m])"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Chain-Write WAL backlog",
      "targets": [
        {"expr": "noc_chain_write_wal_backlog"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "Validation failures rate",
      "targets": [
        {"expr": "rate(noc_validation_failures_total[5m])"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
